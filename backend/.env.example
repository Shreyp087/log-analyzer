FLASK_ENV=development
FLASK_DEBUG=1
APP_HOST=0.0.0.0
APP_PORT=8000

SECRET_KEY=replace-with-at-least-32-char-secret-key
JWT_SECRET_KEY=replace-with-at-least-32-char-jwt-secret

DATABASE_URL=postgresql+psycopg://log_user:log_password@localhost:5432/log_analyzer
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=./uploads
MAX_CONTENT_LENGTH=20971520
OPENAI_API_KEY=sk-...
